# ─── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Both strings come from your Neon dashboard → Connection Details → "Prisma" tab

# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct / unpooled connection (used by Prisma for migrations & db push)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
