# ─── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get both strings from your Neon project dashboard → Connection Details
# "Pooled connection" → DATABASE_URL  (used at runtime by the app)
# "Direct connection" → DIRECT_URL    (used by Prisma for migrations)

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
